@page "/"

<PageTitle>SMSF Audit Platform</PageTitle>

<div class="container mt-4">
    <div class="p-5 mb-4 bg-light rounded-3">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold">SMSF Audit Platform</h1>
            <p class="col-md-8 fs-5 text-muted">
                A modern auditing tool for Self-Managed Superannuation Funds.
                Streamline your audit workflow with structured checklists and AI-assisted guidance.
            </p>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-check2-square text-primary me-2"></i>Audit Checklist
                    </h5>
                    <p class="card-text text-muted">Work through a structured SMSF audit checklist per fund.</p>
                    <a href="/sessions" class="btn btn-primary">Open Checklist</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-bar-chart-fill text-success me-2"></i>Dashboard
                    </h5>
                    <p class="card-text text-muted">View audit progress and completion stats across all funds.</p>
                    <a href="/dashboard" class="btn btn-primary">View Dashboard</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-robot text-warning me-2"></i>AI Assistant
                    </h5>
                    <p class="card-text text-muted">Ask questions about SMSF compliance and audit requirements.</p>
                    <a href="/assistant" class="btn btn-primary">Open Assistant</a>
                </div>
            </div>
        </div>
    </div>
</div>