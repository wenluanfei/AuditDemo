@using Microsoft.AspNetCore.Identity
@using AuditDemo.Models
@inject SignInManager<AppUser> SignInManager
@inject NavigationManager Nav

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill"></i> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="sessions">
                <i class="bi bi-check2-square"></i> Audit Sessions
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <i class="bi bi-bar-chart-fill"></i> Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="assistant">
                <i class="bi bi-robot"></i> AI Assistant
            </NavLink>
        </div>
        <hr />
        @if (SignInManager.IsSignedIn(userPrincipal))
        {
            <div class="nav-item px-3">
                <button class="btn btn-link nav-link text-start" @onclick="Logout">
                    <i class="bi bi-box-arrow-right"></i> Sign Out
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <i class="bi bi-person-fill"></i> Sign In
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? authStateTask { get; set; }

    private System.Security.Claims.ClaimsPrincipal userPrincipal = new();

    protected override async Task OnInitializedAsync()
    {
        if (authStateTask != null)
        {
            var authState = await authStateTask;
            userPrincipal = authState.User;
        }
    }

    private async Task Logout()
    {
        await SignInManager.SignOutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
